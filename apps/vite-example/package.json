{
  "name": "@internal/vite-example",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "run-s test:{typecheck,vitest}",
    "test:typecheck": "tsc --noEmit",
    "test:vitest": "vitest run",
    "lint": "run-s lint:{eslint,prettier}",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check --ignore-path ../../.prettierignore .",
    "fix": "run-s fix:{eslint,prettier}",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@rolldown/plugin-babel": "0.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/babel__core": "7.20.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "4.2.2",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  }
}
