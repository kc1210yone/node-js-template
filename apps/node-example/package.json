{
  "name": "@internal/node-example",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "run-s build:{clean,tsc}",
    "build:clean": "rm -rf ./dist",
    "build:tsc": "tsc",
    "start": "node ./dist/index.js",
    "test": "run-s test:{typecheck,vitest}",
    "test:typecheck": "tsc --noEmit",
    "test:vitest": "vitest run",
    "lint": "run-s lint:{eslint,prettier}",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check --ignore-path ../../.prettierignore .",
    "fix": "run-s fix:{eslint,prettier}",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write --ignore-path ../../.prettierignore ."
  },
  "dependencies": {
    "@internal/shared": "*",
    "dotenv": "17.3.1"
  },
  "devDependencies": {
    "tsx": "4.21.0",
    "vitest": "4.1.0"
  }
}
