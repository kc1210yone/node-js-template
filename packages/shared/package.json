{
  "name": "@internal/shared",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#shared/*": "./dist/src/*"
  },
  "exports": {
    "./*": "./dist/src/*"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "run-s test:{typecheck,vitest}",
    "test:typecheck": "tsc --noEmit",
    "test:vitest": "vitest run",
    "lint:check": "run-s lint:check:{eslint,prettier}",
    "lint:check:eslint": "eslint .",
    "lint:check:prettier": "prettier --check --ignore-path ../../.prettierignore .",
    "lint:fix": "run-s lint:fix:{eslint,prettier}",
    "lint:fix:eslint": "eslint --fix .",
    "lint:fix:prettier": "prettier --write --ignore-path ../../.prettierignore ."
  },
  "devDependencies": {
    "vitest": "4.1.0"
  }
}
