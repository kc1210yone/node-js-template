{
  "name": "node-js-template",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "build": "run-s build:{clean,tsc,tsc-alias}",
    "build:clean": "rm -rf ./dist",
    "build:tsc": "tsc -p ./tsconfig.build.json",
    "build:tsc-alias": "tsc-alias -p ./tsconfig.build.json",
    "start": "node -r dotenv/config ./dist",
    "dev": "nodemon --exec 'ts-node -P ./tsconfig.build.json -r tsconfig-paths/register -r dotenv/config ./src'",
    "test": "run-s test:{typecheck,jest}",
    "test:typecheck": "tsc -p ./tsconfig.build.json --noEmit",
    "test:jest": "jest",
    "lint": "run-s lint:{eslint,prettier}",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "fix": "run-s fix:{eslint,prettier}",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "16.4.7"
  },
  "devDependencies": {
    "@commitlint/cli": "19.7.1",
    "@commitlint/config-conventional": "19.7.1",
    "@eslint/js": "9.19.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.13",
    "@typescript-eslint/eslint-plugin": "8.23.0",
    "@typescript-eslint/parser": "8.23.0",
    "eslint": "9.19.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "15.14.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "15.4.3",
    "nodemon": "3.1.9",
    "npm-run-all": "4.1.5",
    "prettier": "3.4.2",
    "ts-jest": "29.2.6",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.10",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.23.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.13.1"
  }
}
